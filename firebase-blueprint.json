{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A 3D printed product available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered"] },
        "createdAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Public catalog of 3D products"
    },
    "orders": {
      "schema": "Order",
      "description": "User purchases"
    }
  }
}
